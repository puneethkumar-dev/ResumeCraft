# Server Port
PORT=5000

# MongoDB URI connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=resume-craft

# JWT token signing secret
JWT_SECRET=your_jwt_secret_token_here

# Google Gemini API key
GEMINI_API_KEY=mock_gemini_key_for_now

# Environment Mode
NODE_ENV=development
